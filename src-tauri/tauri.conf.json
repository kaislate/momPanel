{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "momPanel",
  "version": "0.4.0",
  "identifier": "com.kaislate.mompanel",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "momPanel",
        "width": 1100,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFENzY5MzkxNTQ5Qzc1QUMKUldTc2RaeFVrWk4ycmVLbEtCbTM4YW9jbktLVC9jQTk2T0hHYlQrK3dxWFRzNlNyaGZxWjNmWWkK",
      "endpoints": [
        "https://github.com/kaislate/momPanel/releases/latest/download/latest.json"
      ]
    }
  }
}
